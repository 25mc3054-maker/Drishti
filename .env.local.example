# Copy to .env.local and set real values (do NOT commit real secrets)

# --- AWS credentials ---
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=eu-north-1
AWS_BEDROCK_REGION=eu-west-1

# --- Storage + database ---
AWS_S3_BUCKET=drishti-shop-images-product
AWS_DYNAMODB_TABLE_ANALYSIS=drishti-analysis
AWS_DYNAMODB_TABLE_BILLING=drishti-billing
AWS_DYNAMODB_TABLE_RECOMMENDATIONS=drishti-recommendations
AWS_DYNAMODB_TABLE_SHOPS=drishti-shops

# --- Cognito ---
AWS_COGNITO_REGION=eu-north-1
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=
AWS_COGNITO_APP_CLIENT_ID=

# --- Bedrock models ---
BEDROCK_MODEL_ID_PRIMARY=
BEDROCK_MODEL_ID=

# --- Notifications + orchestration ---
AWS_SES_SENDER_EMAIL=
AWS_SFN_ARN=
AWS_LAMBDA_ANALYZE_ARN=

# --- Security ---
AWS_SECRET_NAME=Drishti/AppSecret

# Optional: if APIs are hosted separately via API Gateway
NEXT_PUBLIC_API_BASE_URL=

# Google Business Profile (for live Marketing Studio sync)
# Use full location name (recommended): locations/12345678901234567890
# GOOGLE_BUSINESS_LOCATION_NAME=locations/YOUR_LOCATION_ID
# OAuth bearer access token with Business Profile scopes
# GOOGLE_BUSINESS_ACCESS_TOKEN=ya29.your_access_token_here
# Optional CTA URL used for offer posts
# GOOGLE_BUSINESS_CTA_URL=https://maps.google.com
