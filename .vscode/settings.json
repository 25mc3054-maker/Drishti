{
  // Exclude heavy or third-party folders from searches and watchers so analysis tools
  // don't attempt strict JSON.parse on dependency files.
  "files.exclude": {
    "**/node_modules": true,
    "**/.next": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true
  },
  "files.watcherExclude": {
    "**/node_modules/**": true,
    "**/.next/**": true
  },
  // Tailwind directives like @tailwind and @apply are valid via PostCSS/Tailwind.
  // Ignore unknown at-rule warnings from the base CSS language service.
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",
  "less.lint.unknownAtRules": "ignore"
}
